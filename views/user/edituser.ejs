<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit User</title>
</head>
<body>
    <h1>Edit User</h1>
    <form action="/users/<%= user._id %>/save-user" method="POST">
        <p><input type="text" value="<%= user.name %>" name="name" placeholder="Full Name" required /></p>
        <p><input type="email" value="<%= user.email %>" name="email" placeholder="Email" required /></p>
        <p><input type="password" name="password" placeholder="Password (leave empty to keep current)" /></p>
        <p>
            <label>Role: </label>
            <select name="role">
                <option value="user" <% if(user.role === 'user') { %>selected<% } %>>User</option>
                <option value="admin" <% if(user.role === 'admin') { %>selected<% } %>>Admin</option>
            </select>
        </p>
        <p><button>Update</button></p>
    </form>
</body>
</html>
